# ══════════════════════════════════════════
#  RJ Portal — Environment Variables
#  Copy this to .env and fill in values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════

# Required: Anthropic API key for /insights endpoint
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: data.gov.in API key for scheme fetchers
# Defaults to a public demo key if not set
DATA_GOV_API_KEY=579b464db66ec23bdd000001cdd3946e44ce4aad7209ff7b23ac571b

# Frontend -> backend API base URL.
# Local development can leave this empty because CRA proxies requests to localhost:8000.
REACT_APP_API_URL=

# Comma-separated frontend origins allowed to call the backend in production.
# Example: https://unified-portal-cpma.vercel.app
CORS_ORIGINS=https://unified-portal-cpma.vercel.app

# Optional: override default host/port
HOST=0.0.0.0
PORT=8000
