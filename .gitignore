# ════════════════════════════════════════════
#  RJ Portal — Root .gitignore
#  Covers: Python backend, React frontend,
#          Node.js scripts, OS & editor files
# ════════════════════════════════════════════

# ── Python ────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.venv/
venv/
env/
ENV/
.virtualenv/
.python-version
myenv/
dist/
build/
*.egg
*.egg-info/
.eggs/

# ── Node.js ───────────────────────────────
node_modules/
.pnp/
.pnp.js
.yarn/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Build outputs ─────────────────────────
frontend/build/
frontend/dist/
frontend/out/
scripts/dist/

# ── Playwright ────────────────────────────
playwright-report/
test-results/
.playwright/
# Reinstall with: playwright install
# (chromium ~170 MB, don't commit)

# ── Scraped / generated data ──────────────
backend/data/
scripts/data/
data/
scrape_cache/
*.sqlite3
*.db

# ── Environment & secrets ─────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
secrets.json
config.local.py

# ── Logs ─────────────────────────────────
*.log
logs/
pip-log.txt

# ── Cache ────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
frontend/.tmp/

# ── Testing & coverage ────────────────────
.pytest_cache/
.tox/
.coverage
.coverage.*
coverage.xml
htmlcov/
coverage/
.nyc_output/
nosetests.xml

# ── Type checking & linting ───────────────
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# ── OS ───────────────────────────────────
.DS_Store
._*
Thumbs.db
desktop.ini

# ── IDE / Editors ─────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Misc ─────────────────────────────────
*.zip
*.tar.gz
*.bak
tmp/
temp/
LEARNING_README.md
